# Salin ke .env lalu isi. JANGAN commit .env.
# source .env  (atau: export $(grep -v '^#' .env | xargs))

# Personal access token v20 dari OANDA (My Account > My Services > Manage API Access)
OANDA_TOKEN=

# Account ID akun OANDA Web/fxTrade kamu, format xxx-xxx-xxxxxxx-xxx (opsional, untuk cocokkan saat smoke-test)
OANDA_ACCOUNT_ID=

# practice (demo) atau live. Default practice.
OANDA_ENV=practice

# Token bot Telegram untuk daemon alert (buat bot via @BotFather)
TELEGRAM_BOT_TOKEN=

# Chat ID tujuan alert Telegram (getUpdates atau @userinfobot)
TELEGRAM_CHAT_ID=
